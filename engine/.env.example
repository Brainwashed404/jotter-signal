# Copy this file to engine/.env and fill in your Backblaze B2 key.
# engine/.env is git-ignored — it never leaves your machine.
# Create/find a key at: Backblaze → Account → Application Keys (read+write on the bucket).

B2_KEY_ID=your_key_id_here
B2_APP_KEY=your_application_key_here

# Defaults below already match this project — only change if your bucket/region differs.
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_BUCKET=jotter-data

# Optional: set these to also pull emailed newsletters during a local publish.
# GMAIL_USER=jotterintelligence@gmail.com
# GMAIL_APP_PASSWORD=your_16_char_app_password
